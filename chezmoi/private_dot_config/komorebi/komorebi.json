{
  "$schema": "https://komorebi-for-mac.lgug2z.com/komorebi.0.1.0.schema.json",
  "app_specific_configuration_path": "$HOME/.config/komorebi/applications.json",
  "cross_monitor_move_behaviour": "Insert",
  "cross_boundary_behaviour": "Workspace",
  "default_workspace_padding": 15,
  "default_container_padding": 15,
  "border": true,
  "border_width": 6,
  "border_offset": 5,
  "floating_window_aspect_ratio": "Widescreen",
  "floating_layer_behaviour": "Float",
  "resize_delta": 100,
  "ignored_rules": [],
  "floating_applications": [
    {
      "id": "Antinote",
      "kind": "Exe",
      "matching_strategy": "Contains"
    },
    // 1password
    {
      "id": "1Password",
      "kind": "Exe",
      "matching_strategy": "Contains"
    },
    {
      "id": "Session",
      "kind": "Exe",
      "matching_strategy": "Equals"
    },
    {
      "id": "CleanMyMac",
      "kind": "Exe",
      "matching_strategy": "Equals"
    },
    {
      "id": "Dash",
      "kind": "Exe",
      "matching_strategy": "Equals"
    },
    {
      "id": "Surfshark",
      "kind": "Exe",
      "matching_strategy": "Contains"
    },
    {
      "id": "Android Emulator",
      "kind": "Exe",
      "matching_strategy": "Contains"
    }
  ],
  "manage_rules": [],
  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP",
          "initial_workspace_rules": [
            //            {
            //              "kind": "Exe",
            //              "id": "Zen",
            //              "matching_strategy": "Equals"
            //            }
          ]
        }
      ]
    },
    {
      "workspaces": [
        {
          "name": "Monitor 2, Workspace 1",
          "layout": "BSP"
        }
      ]
    }
  ]
}
