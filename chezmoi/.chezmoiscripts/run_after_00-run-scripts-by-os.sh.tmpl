#!/bin/bash

SCRIPTS_DIR={{ .chezmoi.workingTree }}/scripts

{{- if eq .chezmoi.os "darwin" }}
  OS=darwin
{{- else if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "ubuntu") }}
  OS=linux-ubuntu
{{- else if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "debian") }}
  OS=linux-debian
  DEBIAN_PROFILE={{ .debian_profile | quote }}
{{- else }}
  echo "Not supported"
  exit 0
{{- end }}

# Run every *.sh in a directory, ignoring exit codes so one failure doesn't
# block the rest. Silently skips missing/empty directories.
run_scripts_in() {
  dir="$1"
  [ -d "$dir" ] || return 0
  for script in "$dir"/*.*sh; do
    [ -e "$script" ] || continue
    echo "$script"
    bash "$script" || true
  done
}

# Base scripts for this OS (always run).
run_scripts_in "$SCRIPTS_DIR/$OS"

# Debian profiles are additive: the minimal base above runs for every profile,
# then the selected profile's folder layers extra tools on top.
if [ "$OS" = "linux-debian" ] && [ -n "${DEBIAN_PROFILE:-}" ]; then
  echo "Debian profile: $DEBIAN_PROFILE"
  run_scripts_in "$SCRIPTS_DIR/$OS/$DEBIAN_PROFILE"
fi
